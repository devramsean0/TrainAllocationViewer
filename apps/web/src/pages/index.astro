---
import Layout from '@/layouts/layout.astro';
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import {
  Field,
  FieldContent,
  FieldDescription,
  FieldError,
  FieldGroup,
  FieldLabel,
  FieldLegend,
  FieldSeparator,
  FieldSet,
  FieldTitle,
} from "@/components/ui/field";
import LocationSearch from '@/components/LocationSearch';
---
<Layout title="Search">
	<div class="flex flex-col justify-center items-center min-h-screen">
		<main class="w-1/3 h-1/2 items-center">
			<Card className="flex-none">
				<CardHeader>
					<CardTitle>Search</CardTitle>
					<CardDescription>Search our system for allocations</CardDescription>
				</CardHeader>
				<CardContent>
					<form class="flex flex-col gap-2" action="/train/list">
						<Field>
							<FieldLabel htmlFor="class">Train Class
								<span class="text-destructive">*</span>
							</FieldLabel>
							<Input name="fleet" type="text" placeholder="810/0" required/>
						</Field>
						<Field>
							<FieldLabel htmlFor="date">Date
								<span class="text-destructive">*</span>
							</FieldLabel>
							<Input name="date" type="date" placeholder="" required/>
						</Field>
						<FieldGroup className="grid grid-cols-2 gap-2">
							<Field>
								<FieldLabel htmlFor="origin_location">Start Location</FieldLabel>
								<LocationSearch name="origin_location" placeholder="Start location" client:load/>
							</Field>
							<Field>
								<FieldLabel htmlFor="dest_location">End Location</FieldLabel>
								<LocationSearch name="dest_location" placeholder="End Location" client:load/>
							</Field>
						</FieldGroup>
						<Button type="submit">Search</Button>
					</form>
				</CardContent>
			</Card>
		</main>
	</div>
</Layout>