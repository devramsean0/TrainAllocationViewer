---
import Layout from '@/layouts/layout.astro';
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card";
import {
  Field,
  FieldContent,
  FieldDescription,
  FieldError,
  FieldGroup,
  FieldLabel,
  FieldLegend,
  FieldSeparator,
  FieldSet,
  FieldTitle,
} from "@/components/ui/field";
---
<Layout title="Search">
	<main class="w-1/3 h-1/2 items-center">
		<Card className="flex-none">
			<CardHeader>
				<CardTitle>Search</CardTitle>
				<CardDescription>Search our system for allocations</CardDescription>
			</CardHeader>
			<CardContent>
				<form class="flex flex-col gap-2" action="/train/list">
					<Field>
						<FieldLabel htmlFor="class">Train Class
							<span class="text-destructive">*</span>
						</FieldLabel>
						<Input name="class" type="text" placeholder="810/0" required=true/>
					</Field>
					<Field>
						<FieldLabel htmlFor="date">Date
							<span class="text-destructive">*</span>
						</FieldLabel>
						<Input name="date" type="date" placeholder="" required=true/>
					</Field>
					<FieldGroup className="grid grid-cols-2 gap-2">
						<Field>
							<FieldLabel htmlFor="start_location">Start Location</FieldLabel>
							<Input name="origin_location" type="text" />
						</Field>
						<Field>
							<FieldLabel htmlFor="end_location">End Location</FieldLabel>
							<Input name="dest_location" type="text" />
						</Field>
					</FieldGroup>
					<Button type="submit">Search</Button>
				</form>
			</CardContent>
		</Card>
	</main>
</Layout>